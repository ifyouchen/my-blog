<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.myblog.growth.infrastructure.repository.persistence.mapper.PointRuleConfigMapper">

    <resultMap id="BaseResultMap" type="com.myblog.growth.infrastructure.repository.persistence.entity.PointRuleConfigDO">
        <id     column="id"           property="id"/>
        <result column="source_type"  property="sourceType"/>
        <result column="point_amount" property="pointAmount"/>
        <result column="daily_limit"  property="dailyLimit"/>
        <result column="enabled"      property="enabled"/>
        <result column="operator"     property="operator"/>
        <result column="reason"       property="reason"/>
        <result column="created_at"   property="createdAt"/>
        <result column="updated_at"   property="updatedAt"/>
        <result column="deleted_at"   property="deletedAt"/>
        <result column="version"      property="version"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, source_type, point_amount, daily_limit, enabled,
        operator, reason, created_at, updated_at, deleted_at, version
    </sql>

    <!-- 根据来源类型查询规则（排除软删除） -->
    <select id="selectBySourceType" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM point_rule_config
        WHERE source_type = #{sourceType}
          AND deleted_at IS NULL
        LIMIT 1
    </select>

    <!-- 查询所有已启用且未软删除的规则 -->
    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM point_rule_config
        WHERE enabled   = 1
          AND deleted_at IS NULL
        ORDER BY id ASC
    </select>

</mapper>

