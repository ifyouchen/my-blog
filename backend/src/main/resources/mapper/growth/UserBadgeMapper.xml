<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.myblog.growth.infrastructure.repository.persistence.mapper.UserBadgeMapper">

    <resultMap id="BaseResultMap" type="com.myblog.growth.domain.model.valueobject.UserBadge">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="badge_code" property="badgeCode"/>
        <result column="source_type" property="sourceType"/>
        <result column="source_id" property="sourceId"/>
        <result column="granted_at" property="grantedAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="version" property="version"/>
    </resultMap>

    <resultMap id="BadgeDefinitionResultMap" type="com.myblog.growth.domain.model.valueobject.BadgeDefinition">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="type" property="type"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="icon_key" property="iconKey"/>
        <result column="tone" property="tone"/>
        <result column="rarity" property="rarity"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, badge_code, source_type, source_id, granted_at,
        created_at, updated_at, version
    </sql>

    <insert id="insertIgnore">
        INSERT IGNORE INTO user_badge
            (user_id, badge_code, source_type, source_id)
        VALUES
            (#{userId}, #{badgeCode}, #{sourceType}, #{sourceId})
    </insert>

    <select id="countByUserIdAndBadgeCode" resultType="int">
        SELECT COUNT(1)
        FROM user_badge
        WHERE user_id = #{userId}
          AND badge_code = #{badgeCode}
          AND deleted_at IS NULL
    </select>

    <select id="selectCodesByUserId" resultType="string">
        SELECT badge_code
        FROM user_badge
        WHERE user_id = #{userId}
          AND deleted_at IS NULL
        ORDER BY granted_at ASC, id ASC
    </select>

    <select id="selectOwnedDefinitions" resultMap="BadgeDefinitionResultMap">
        SELECT d.id, d.code, d.type, d.name, d.description, d.icon_key, d.tone, d.rarity,
               d.sort_order, d.enabled, d.created_at, d.updated_at, d.version
        FROM user_badge ub
        JOIN badge_definition d
          ON d.code = ub.badge_code
         AND d.enabled = 1
         AND d.deleted_at IS NULL
        WHERE ub.user_id = #{userId}
          AND ub.deleted_at IS NULL
        ORDER BY d.sort_order ASC, d.id ASC
    </select>
</mapper>
