<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.myblog.growth.infrastructure.repository.persistence.mapper.LevelPrivilegeMapper">

    <resultMap id="BaseResultMap" type="com.myblog.growth.domain.model.valueobject.LevelPrivilegeConfig">
        <id column="id" property="id"/>
        <result column="level" property="level"/>
        <result column="privilege_code" property="privilegeCode"/>
        <result column="privilege_name" property="privilegeName"/>
        <result column="description" property="description"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="version" property="version"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, level, privilege_code, privilege_name, description, enabled,
        created_at, updated_at, version
    </sql>

    <select id="selectEnabledByLevel" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM level_privilege_config
        WHERE level = #{level}
          AND enabled = 1
          AND deleted_at IS NULL
        ORDER BY id ASC
    </select>

    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM level_privilege_config
        WHERE enabled = 1
          AND deleted_at IS NULL
        ORDER BY level ASC, id ASC
    </select>
</mapper>
