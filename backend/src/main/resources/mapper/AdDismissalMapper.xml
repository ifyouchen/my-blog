<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.myblog.infrastructure.repository.persistence.mapper.AdDismissalMapper">

    <insert id="insert">
        INSERT INTO `blog_user_ad_dismissal` (`user_id`, `ad_id`, `dismissed_at`)
        VALUES (#{userId}, #{adId}, #{dismissedAt})
        ON DUPLICATE KEY UPDATE `dismissed_at` = VALUES(`dismissed_at`)
    </insert>

    <select id="selectDismissedAdIds" resultType="long">
        SELECT `ad_id`
        FROM `blog_user_ad_dismissal`
        WHERE `user_id` = #{userId}
          AND `dismissed_at` >= #{since}
    </select>

</mapper>
